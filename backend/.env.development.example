NODE_ENV=development

PORT=5002
FRONTEND_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3002

MONGO_URI=mongodb://cogmemory_ad_dev_app:{COGMEMORY_AD_DEV_APP_PASSWORD}@127.0.0.1:27017/cogmemory_ad_dev?authSource=cogmemory_ad_dev
MONGO_ADMIN_URI=mongodb://cogmemory_ad_dev_db_admin:{COGMEMORY_AD_DEV_DB_ADMIN_PASSWORD}@127.0.0.1:27017/cogmemory_ad_dev?authSource=cogmemory_ad_dev
MONGO_AUTO_INDEX=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Storage / OSS
# Local development defaults to fake storage.
# STORAGE_DRIVER=fake 时使用代码默认 fake storage 配置，不需要 OSS_BUCKET / OSS_OBJECT_PREFIX。
# STORAGE_DRIVER=oss 时才需要配置 OSS bucket、endpoint 与 AccessKey，占位值请参考 production example。
STORAGE_DRIVER=fake

SESSION_COOKIE_NAME=cogmemory_ad_session
SESSION_TTL_MS=86400000
MAX_ACTIVE_SESSIONS_PER_USER=5
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

LLM_PROVIDER=bailian
BAILIAN_API_KEY={BAILIAN_API_KEY}
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.6-plus
BAILIAN_TIMEOUT_MS=90000
BAILIAN_MAX_RETRIES=1

# 阿里云 SMS 示例 / 待确认配置，当前仅占位，不代表短信服务已实现
ALIYUN_SMS_ACCESS_KEY_ID={COGMEMORY_AD_ALIYUN_SMS_ACCESS_KEY_ID}
ALIYUN_SMS_ACCESS_KEY_SECRET={COGMEMORY_AD_ALIYUN_SMS_ACCESS_KEY_SECRET}
ALIYUN_SMS_SIGN_NAME={COGMEMORY_AD_ALIYUN_SMS_SIGN_NAME}
ALIYUN_SMS_TEMPLATE_CODE={COGMEMORY_AD_ALIYUN_SMS_TEMPLATE_CODE}
ALIYUN_SMS_TEMPLATE_PARAM={COGMEMORY_AD_ALIYUN_SMS_TEMPLATE_PARAM}
