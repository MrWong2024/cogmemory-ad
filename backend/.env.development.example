NODE_ENV=development

PORT=5002
FRONTEND_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3002

MONGO_URI=mongodb://cogmemory_ad_dev_app:{COGMEMORY_AD_DEV_APP_PASSWORD}@127.0.0.1:27017/cogmemory_ad_dev?authSource=cogmemory_ad_dev
MONGO_ADMIN_URI=mongodb://cogmemory_ad_dev_db_admin:{COGMEMORY_AD_DEV_DB_ADMIN_PASSWORD}@127.0.0.1:27017/cogmemory_ad_dev?authSource=cogmemory_ad_dev
MONGO_AUTO_INDEX=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Storage / OSS
# Local development defaults to fake storage. Use oss only for future real OSS integration.
# OSS_BUCKET is a placeholder; replace it only when testing real OSS integration.
# Do not commit real OSS_ACCESS_KEY_ID or OSS_ACCESS_KEY_SECRET.
# Do not use an Alibaba Cloud root account AccessKey. Use a least-privilege RAM user or a future RAM Role.
# OSS_INTERNAL_ENDPOINT is for same-region ECS backend access. Local machines usually cannot access it.
# OSS_PUBLIC_ENDPOINT is for browser-accessible signed download/preview URLs.
# Bucket should be private read/write; backend will generate short-lived signed URLs in a later phase.
STORAGE_DRIVER=fake
OSS_REGION=oss-cn-shenzhen
OSS_BUCKET={COGMEMORY_AD_OSS_BUCKET}
OSS_INTERNAL_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_PUBLIC_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_ACCESS_KEY_ID={your-ram-access-key-id}
OSS_ACCESS_KEY_SECRET={your-ram-access-key-secret}
OSS_OBJECT_PREFIX=cogmemory_ad

SESSION_COOKIE_NAME=cogmemory_ad_session
SESSION_TTL_MS=86400000
MAX_ACTIVE_SESSIONS_PER_USER=5
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

LLM_PROVIDER=bailian
BAILIAN_API_KEY={BAILIAN_API_KEY}
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.6-plus
BAILIAN_TIMEOUT_MS=90000
BAILIAN_MAX_RETRIES=1

SMS_AUTH_PROVIDER=aliyun
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_REGION_ID=cn-shenzhen
ALIYUN_SMS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_SMS_COUNTRY_CODE=86
ALIYUN_SMS_SIGN_NAME=速通互联验证码
ALIYUN_SMS_TEMPLATE_CODE=100001
ALIYUN_SMS_TEMPLATE_PARAM='{"code":"##code##","min":"5"}'
ALIYUN_SMS_CODE_LENGTH=6
ALIYUN_SMS_VALID_TIME_SECONDS=300
ALIYUN_SMS_DUPLICATE_POLICY=1
ALIYUN_SMS_INTERVAL_SECONDS=60
ALIYUN_SMS_CODE_TYPE=1
ALIYUN_SMS_CASE_AUTH_POLICY=1