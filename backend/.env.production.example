NODE_ENV=production

PORT=5002
FRONTEND_URL=https://your-cogmemory-ad-frontend-domain.example
CORS_ORIGIN=https://your-cogmemory-ad-frontend-domain.example

# MongoDB
# For Alibaba Cloud MongoDB replica set, use the VPC/private connection string.
# Passwords in MongoDB URI must be URL-encoded, for example "$" -> "%24".
MONGO_URI=mongodb://cogmemory_ad_app:{URL_ENCODED_COGMEMORY_AD_APP_PASSWORD}@{HOST1}:3717,{HOST2}:3717/cogmemory_ad?authSource=admin&replicaSet={REPLICA_SET}
MONGO_ADMIN_URI=mongodb://cogmemory_ad_db_admin:{URL_ENCODED_COGMEMORY_AD_DB_ADMIN_PASSWORD}@{HOST1}:3717,{HOST2}:3717/cogmemory_ad?authSource=admin&replicaSet={REPLICA_SET}
MONGO_AUTO_INDEX=false
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Storage / OSS
# 阿里云 OSS 示例 / 待确认配置；当前仅占位，不代表 OSS Service 已实现。
# Do not commit real OSS AccessKey values.
# Do not use an Alibaba Cloud root account AccessKey. Use least-privilege RAM credentials when confirmed.
# OSS_INTERNAL_ENDPOINT is for same-region ECS backend access over Alibaba Cloud internal network.
# OSS_PUBLIC_ENDPOINT is for browser-accessible signed download/preview URLs.
# Bucket policy and signed URL behavior are pending future OSS Service design.
STORAGE_DRIVER=oss
OSS_REGION=oss-cn-shenzhen
OSS_BUCKET={COGMEMORY_AD_OSS_BUCKET}
OSS_INTERNAL_ENDPOINT=oss-cn-shenzhen-internal.aliyuncs.com
OSS_PUBLIC_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_ACCESS_KEY_ID={COGMEMORY_AD_OSS_ACCESS_KEY_ID}
OSS_ACCESS_KEY_SECRET={COGMEMORY_AD_OSS_ACCESS_KEY_SECRET}
OSS_OBJECT_PREFIX=cogmemory_ad

SESSION_COOKIE_NAME=cogmemory_ad_session
SESSION_TTL_MS=86400000
MAX_ACTIVE_SESSIONS_PER_USER=5
# Keep Secure enabled for formal HTTPS/domain deployments.
# For HTTP-only IP, intranet, or temporary trial deployments, explicitly set:
# SESSION_COOKIE_SECURE=false
# When Secure is false, SESSION_COOKIE_SAME_SITE must not be none; keep lax.
# Do not disable Secure for real public production HTTPS deployments.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax

LLM_PROVIDER=bailian
BAILIAN_API_KEY={BAILIAN_API_KEY}
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.6-plus
BAILIAN_TIMEOUT_MS=90000
BAILIAN_MAX_RETRIES=1

# 阿里云 SMS 示例 / 待确认配置；当前仅占位，不代表 SMS Service 已实现。
# Phone number is runtime request data when SMS sending is implemented, not an env value.
SMS_AUTH_PROVIDER=aliyun
ALIYUN_SMS_ACCESS_KEY_ID={COGMEMORY_AD_ALIYUN_SMS_ACCESS_KEY_ID}
ALIYUN_SMS_ACCESS_KEY_SECRET={COGMEMORY_AD_ALIYUN_SMS_ACCESS_KEY_SECRET}
ALIYUN_SMS_REGION_ID={COGMEMORY_AD_ALIYUN_SMS_REGION_ID}
ALIYUN_SMS_ENDPOINT={COGMEMORY_AD_ALIYUN_SMS_ENDPOINT}
ALIYUN_SMS_COUNTRY_CODE={COGMEMORY_AD_ALIYUN_SMS_COUNTRY_CODE}
ALIYUN_SMS_SIGN_NAME={COGMEMORY_AD_ALIYUN_SMS_SIGN_NAME}
ALIYUN_SMS_TEMPLATE_CODE={COGMEMORY_AD_ALIYUN_SMS_TEMPLATE_CODE}
ALIYUN_SMS_TEMPLATE_PARAM={COGMEMORY_AD_ALIYUN_SMS_TEMPLATE_PARAM}

# 项目验证码策略示例 / 待确认配置；不是阿里云 SendSms API 必填字段。
ALIYUN_SMS_CODE_LENGTH={COGMEMORY_AD_ALIYUN_SMS_CODE_LENGTH}
ALIYUN_SMS_VALID_TIME_SECONDS={COGMEMORY_AD_ALIYUN_SMS_VALID_TIME_SECONDS}
ALIYUN_SMS_DUPLICATE_POLICY={COGMEMORY_AD_ALIYUN_SMS_DUPLICATE_POLICY}
ALIYUN_SMS_INTERVAL_SECONDS={COGMEMORY_AD_ALIYUN_SMS_INTERVAL_SECONDS}
ALIYUN_SMS_CODE_TYPE={COGMEMORY_AD_ALIYUN_SMS_CODE_TYPE}
ALIYUN_SMS_CASE_AUTH_POLICY={COGMEMORY_AD_ALIYUN_SMS_CASE_AUTH_POLICY}
