NODE_ENV=test

PORT=5002
FRONTEND_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3002

MONGO_URI=mongodb://cogmemory_ad_test_app:{COGMEMORY_AD_TEST_APP_PASSWORD}@127.0.0.1:27017/cogmemory_ad_test?authSource=cogmemory_ad_test
MONGO_ADMIN_URI=mongodb://cogmemory_ad_test_db_admin:{COGMEMORY_AD_TEST_DB_ADMIN_PASSWORD}@127.0.0.1:27017/cogmemory_ad_test?authSource=cogmemory_ad_test
MONGO_AUTO_INDEX=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Storage / OSS
# Automated tests must not depend on real Alibaba Cloud OSS.
# Later fake storage or mock storage should be used for test automation.
# This task only records env examples; it does not implement FakeStorageService.
STORAGE_DRIVER=fake
OSS_BUCKET=cogmemory-ad-test-materials
OSS_OBJECT_PREFIX=cogmemory_ad

SESSION_COOKIE_NAME=cogmemory_ad_session
SESSION_TTL_MS=86400000
MAX_ACTIVE_SESSIONS_PER_USER=5
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

LLM_PROVIDER=stub
